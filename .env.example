# Server environment variables
# Copy this file to server/.env and set real values.

# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Runtime
PORT=3001
# Set true to let Express serve ../dist as frontend (single-domain deploy)
SERVE_STATIC=true

# CORS (use either CORS_ORIGIN or ALLOWED_ORIGINS)
# Single origin:
CORS_ORIGIN=https://your-domain.com
# Multiple origins (comma-separated):
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional
ADMIN_IDENTIFIERS=admin@example.com,owner@example.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PEXELS_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MPESA_BUSINESS_NUMBER=400200
MPESA_ACCOUNT_NO=11317282
MPESA_BUSINESS_NAME=Murekefu Music Hub
MPESA_PAYMENT_URL=https://paynecta.co.ke/pay/music-hub
